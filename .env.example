# Django settings — copy this file to .env and fill in the values.
# In production, set DJANGO_DEBUG=False and generate a unique SECRET_KEY.

DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Email — Gmail SMTP
# ---------------------------------------------------------------------------
# 1. Ative a verificação em 2 passos na sua conta Google:
#    https://myaccount.google.com/security
# 2. Crie uma Palavra-passe de App em:
#    https://myaccount.google.com/apppasswords
#    (Selecione "Outra (nome personalizado)" → ex: "DjangoDecent")
# 3. Copie a palavra-passe de 16 caracteres gerada para EMAIL_HOST_PASSWORD.
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=o-seu-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=Decent Privé <o-seu-email@gmail.com>

# SMS gateway (optional)
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
