# Django settings — copy this file to .env and fill in the values.
# In production, set DJANGO_DEBUG=False and generate a unique SECRET_KEY.

DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# SMS gateway (optional)
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
